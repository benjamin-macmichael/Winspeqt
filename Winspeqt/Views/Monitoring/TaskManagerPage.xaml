<Page
    x:Class="Winspeqt.Views.Monitoring.TaskManagerPage"
    x:Name="TaskManagerPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="← Back"
                    Click="BackButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="16"
                    Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        Text="Friendly Task Manager"
                        FontSize="36"
                        FontWeight="Bold"/>
                    <TextBlock
                        Text="See what's using your computer's resources"
                        FontSize="18"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="0,4,0,0"/>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Content="{Binding RefreshButtonText, Mode=OneWay}"
                    Command="{Binding RefreshCommand}"
                    FontSize="16"
                    Padding="16,8"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,0,12,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xEC4E;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#2196F3"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Processor (CPU)"
                                VerticalAlignment="Center"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>

                        <TextBlock
                            Text="{Binding TotalCpuUsage, Mode=OneWay}"
                            FontSize="48"
                            FontWeight="Bold"
                            Foreground="#2196F3"/>
                        <TextBlock
                            Text="%"
                            FontSize="24"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,-8,0,16"/>

                        <TextBlock
                            Text="{Binding CpuStatusMessage, Mode=OneWay}"
                            FontSize="15"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="22"/>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="12,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE7F1;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#FF9800"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Memory (RAM)"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="{Binding UsedMemoryMB, Mode=OneWay}"
                                FontSize="48"
                                FontWeight="Bold"
                                Foreground="#FF9800"/>
                            <TextBlock
                                Text=" / "
                                FontSize="32"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="8,0"/>
                            <TextBlock
                                Text="{Binding TotalMemoryMB, Mode=OneWay}"
                                FontSize="32"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock
                            Text="MB"
                            FontSize="20"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,-4,0,16"/>

                        <TextBlock
                            Text="{Binding MemoryStatusMessage, Mode=OneWay}"
                            FontSize="15"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="22"/>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,12,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE774;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#4CAF50"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Network"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>

                        <TextBlock
                            Text="{Binding NetworkUsage, Mode=OneWay}"
                            FontSize="48"
                            FontWeight="Bold"
                            Foreground="#4CAF50"/>
                        <TextBlock
                            Text="Mbps"
                            FontSize="24"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,-8,0,16"/>

                        <TextBlock
                            Text="{Binding NetworkStatusMessage, Mode=OneWay}"
                            FontSize="15"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="22"/>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="12,12,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE74E;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#9C27B0"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Disk"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>

                        <TextBlock
                            Text="{Binding DiskUsage, Mode=OneWay}"
                            FontSize="48"
                            FontWeight="Bold"
                            Foreground="#9C27B0"/>
                        <TextBlock
                            Text="%"
                            FontSize="24"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,-8,0,16"/>

                        <TextBlock
                            Text="{Binding DiskStatusMessage, Mode=OneWay}"
                            FontSize="15"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="22"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock
                        Text="Show:"
                        FontSize="16"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ComboBox
                        ItemsSource="{Binding FilterOptions}"
                        SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                        MinWidth="150"
                        FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock
                        Text="Sort by:"
                        FontSize="16"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ComboBox
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                        MinWidth="150"
                        FontSize="15"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Spacing="16">
                <StackPanel>
                    <TextBlock
                        Text="Top Apps Using Resources"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Margin="0,0,0,16"/>

                    <ItemsRepeater ItemsSource="{Binding ProcessGroups, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,12">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid Visibility="{Binding HasChildren, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <Grid Padding="20" HorizontalAlignment="Stretch" MinHeight="112">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Grid.Column="0"
                                                    Width="48"
                                                    Height="48"
                                                    Background="#DCEEFF"
                                                    CornerRadius="12"
                                                    Margin="0,0,18,0"
                                                    VerticalAlignment="Center">
                                                    <FontIcon
                                                        Glyph="&#xE7C4;"
                                                        FontSize="22"
                                                        Foreground="#1565C0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="0,2,0,0">
                                                    <TextBlock
                                                        Text="{Binding DisplayName}"
                                                        FontSize="17"
                                                        FontWeight="SemiBold"/>
                                                    <TextBlock
                                                        Text="{Binding ProcessCountDisplay}"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        CharacterSpacing="10"/>
                                                    <TextBlock
                                                        Text="{Binding FriendlyExplanation}"
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        TextWrapping="Wrap"
                                                        MaxWidth="560"
                                                        Margin="0,6,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Margin="20,0" VerticalAlignment="Center" MinWidth="80">
                                                    <TextBlock
                                                        Text="CPU"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        HorizontalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                        <TextBlock
                                                            Text="{Binding CpuUsagePercent}"
                                                            FontSize="18"
                                                            FontWeight="SemiBold"
                                                            Foreground="#2196F3"/>
                                                        <TextBlock
                                                            Text="%"
                                                            FontSize="18"
                                                            FontWeight="SemiBold"
                                                            Foreground="#2196F3"
                                                            Margin="2,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="20,0" VerticalAlignment="Center" MinWidth="100">
                                                    <TextBlock
                                                        Text="Memory"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        HorizontalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                        <TextBlock
                                                            Text="{Binding MemoryUsageMB}"
                                                            FontSize="18"
                                                            FontWeight="SemiBold"
                                                            Foreground="#FF9800"/>
                                                        <TextBlock
                                                            Text=" MB"
                                                            FontSize="18"
                                                            FontWeight="SemiBold"
                                                            Foreground="#FF9800"
                                                            Margin="4,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" Margin="20,0,0,0" VerticalAlignment="Center">
                                                    <Button
                                                        Command="{Binding DataContext.RestartProcessCommand, ElementName=TaskManagerPageRoot}"
                                                        CommandParameter="{Binding RootProcess}"
                                                        Foreground="#616161"
                                                        Background="Transparent"
                                                        BorderBrush="#616161"
                                                        BorderThickness="1"
                                                        Padding="12,8">
                                                        <Button.Resources>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#616161"/>
                                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                                        </Button.Resources>
                                                        <StackPanel Orientation="Horizontal">
                                                            <FontIcon 
                                                                Glyph="&#xE72C;" 
                                                                FontFamily="Segoe MDL2 Assets" 
                                                                VerticalAlignment="Center"
                                                                FontSize="15"
                                                                Margin="0,0,4,0"/>
                                                            <TextBlock Text="Restart" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                        Command="{Binding DataContext.EndProcessCommand, ElementName=TaskManagerPageRoot}"
                                                        CommandParameter="{Binding RootProcess}"
                                                        Background="#F44336"
                                                        Foreground="White"
                                                        Padding="12,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <FontIcon 
                                                                Glyph="&#xE71A;" 
                                                                FontFamily="Segoe MDL2 Assets" 
                                                                VerticalAlignment="Center"
                                                                FontSize="15"
                                                                Margin="0,0,4,0"/>
                                                            <TextBlock Text="End Task" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                                <Border
                                                    Grid.Column="5"
                                                    Width="32"
                                                    Height="32"
                                                    Margin="12,0,0,0"
                                                    Background="Transparent"/>
                                            </Grid>
                                        </Grid>

                                        <Grid Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Padding="20" HorizontalAlignment="Stretch" MinHeight="112">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Width="48"
                                                        Height="48"
                                                        Background="#DCEEFF"
                                                        CornerRadius="12"
                                                        Margin="0,0,18,0"
                                                        VerticalAlignment="Center">
                                                        <FontIcon
                                                            Glyph="&#xE7C4;"
                                                            FontSize="22"
                                                            Foreground="#1565C0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="0,2,0,0">
                                                        <TextBlock
                                                            Text="{Binding DisplayName}"
                                                            FontSize="17"
                                                            FontWeight="SemiBold"/>
                                                        <TextBlock
                                                            Text="{Binding ProcessCountDisplay}"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            CharacterSpacing="10"/>
                                                        <TextBlock
                                                            Text="{Binding FriendlyExplanation}"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            TextWrapping="Wrap"
                                                            MaxWidth="560"
                                                            Margin="0,6,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="20,0" VerticalAlignment="Center" MinWidth="80">
                                                        <TextBlock
                                                            Text="CPU"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            HorizontalAlignment="Center"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                            <TextBlock
                                                                Text="{Binding CpuUsagePercent}"
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Foreground="#2196F3"/>
                                                            <TextBlock
                                                                Text="%"
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Foreground="#2196F3"
                                                                Margin="2,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="20,0" VerticalAlignment="Center" MinWidth="100">
                                                        <TextBlock
                                                            Text="Memory"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            HorizontalAlignment="Center"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                            <TextBlock
                                                                Text="{Binding MemoryUsageMB}"
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Foreground="#FF9800"/>
                                                            <TextBlock
                                                                Text=" MB"
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Foreground="#FF9800"
                                                                Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" Margin="20,0,0,0" VerticalAlignment="Center">
                                                    <Button
                                                            Command="{Binding DataContext.RestartProcessCommand, ElementName=TaskManagerPageRoot}"
                                                            CommandParameter="{Binding RootProcess}"
                                                            Foreground="#616161"
                                                            Background="Transparent"
                                                            BorderBrush="#616161"
                                                            BorderThickness="1"
                                                            Padding="12,8">
                                                        <Button.Resources>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#616161"/>
                                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                                        </Button.Resources>
                                                        <StackPanel Orientation="Horizontal">
                                                            <FontIcon 
                                                                Glyph="&#xE72C;" 
                                                                FontFamily="Segoe MDL2 Assets" 
                                                                VerticalAlignment="Center"
                                                                FontSize="15"
                                                                Margin="0,0,4,0"/>
                                                            <TextBlock Text="Restart" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                            Command="{Binding DataContext.EndProcessCommand, ElementName=TaskManagerPageRoot}"
                                                            CommandParameter="{Binding RootProcess}"
                                                            Background="#F44336"
                                                            Foreground="White"
                                                            Padding="12,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <FontIcon 
                                                                Glyph="&#xE71A;" 
                                                                FontFamily="Segoe MDL2 Assets" 
                                                                VerticalAlignment="Center"
                                                                FontSize="15"
                                                                Margin="0,0,4,0"/>
                                                            <TextBlock Text="End Task" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                                <ToggleButton
                                                        Grid.Column="5"
                                                        IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                        Width="32"
                                                        Height="32"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0">
                                                        <FontIcon
                                                            Glyph="&#xE70D;"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </ToggleButton>
                                                </Grid>

                                            <ItemsRepeater Grid.Row="1" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}" ItemsSource="{Binding ChildProcesses}">
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1,1,1,0"
                                                            Padding="20,16,20,16"
                                                            Margin="20,0,20,0"
                                                            HorizontalAlignment="Stretch">
                                                            <Grid HorizontalAlignment="Stretch">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock
                                                                        Text="{Binding Description}"
                                                                        FontSize="16"
                                                                        FontWeight="SemiBold"/>
                                                                    <TextBlock
                                                                        Text="{Binding ProcessName}"
                                                                        FontSize="13"
                                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                        Margin="0,4,0,0"/>
                                                                </StackPanel>

                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Text="{Binding CpuUsageDisplay}"
                                                                    FontSize="16"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#2196F3"
                                                                    Margin="16,0"/>

                                                                <TextBlock
                                                                    Grid.Column="2"
                                                                    Text="{Binding MemoryUsageDisplay}"
                                                                    FontSize="16"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#FF9800"
                                                                    Margin="16,0"/>

                                                                <Button
                                                                    Grid.Column="3"
                                                                    Content="End"
                                                                    Command="{Binding DataContext.EndProcessCommand, ElementName=TaskManagerPageRoot}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="#F44336"
                                                                    Foreground="White"
                                                                    Padding="10,6"
                                                                    Margin="16,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>

            <Border
                Grid.Row="0"
                Grid.RowSpan="4"
                Background="#CC000000"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing
                        IsActive="True"
                        Width="80"
                        Height="80"/>
                    <TextBlock
                        Text="Loading system information..."
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
