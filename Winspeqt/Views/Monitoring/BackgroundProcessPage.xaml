<Page
    x:Class="Winspeqt.Views.Monitoring.BackgroundProcessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winspeqt.Views"
    xmlns:viewmodels="using:Winspeqt.ViewModels.Monitoring"
    xmlns:models="using:Winspeqt.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    xmlns:monitoring="using:Winspeqt.ViewModels.Monitoring"

    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.DataContext>
        <viewmodels:BackgroundProcessViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <helpers:CollectionCountToVisibilityConverter x:Key="CollectionCountToVisibilityConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
        <helpers:StringToBrushConverter x:Key="StringToBrushConverter"/>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  CARD VIEW — compact process card template (existing style)        -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="ProcessGridCardTemplate" x:DataType="models:ProcessInfo">
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="12"
                Padding="20"
                MinHeight="140"
                HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Icon and title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                        <Border Width="40" Height="40" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0"/>
                                    <GradientStop Color="{ThemeResource SystemAccentColorLight1}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{x:Bind Icon}" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Description}" FontSize="15" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind ProcessName}" FontSize="11" FontFamily="Consolas"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Memory usage -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12,0,12">
                        <TextBlock Text="Memory Usage" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{x:Bind MemoryUsageDisplay}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0">
                            <Run Text="Running: "/>
                            <Run Text="{x:Bind RunningTimeFormatted, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Actions -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                            <TextBlock Text="{x:Bind Status}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                        </Border>

                        <Button Grid.Column="1"
                                Click="EndProcess_Click" Tag="{x:Bind}"
                                Visibility="{x:Bind IsEndable, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="#F44336" Foreground="White" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon
                                    Glyph="&#xE71A;"
                                    FontFamily="Segoe MDL2 Assets"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Margin="0,0,4,0"/>
                                <TextBlock Text="End Task"/>
                            </StackPanel>
                        </Button>

                        <Border Grid.Column="1"
                                Visibility="{x:Bind IsProtected, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="10,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72E;" FontSize="11"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="System" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  TABLE VIEW — expandable process group row                         -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="ProcessGroupRowTemplate" x:DataType="models:ProcessGroup">
            <StackPanel>

                <!-- Root process row -->
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1" MinHeight="48">
                    <Grid HorizontalAlignment="Stretch" Padding="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <!-- Name cell (click to expand) -->
                        <Button Grid.Column="0"
                                Click="ExpandProcess_Click" Tag="{x:Bind}"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="4,8">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <!-- Chevron — only visible when HasChildren -->
                                <Grid Width="18">
                                    <Grid Visibility="{x:Bind HasChildren, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xE76C;" FontSize="11"
                                                  Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToCollapsedConverter}}"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <FontIcon Glyph="&#xE70D;" FontSize="11"
                                                  Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </Grid>
                                <!-- Name + process count -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind ProcessCountDisplay}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Running time -->
                        <TextBlock Grid.Column="1" Text="{x:Bind RunningTimeFormatted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <!-- Action -->
                        <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Click="EndProcess_Click" Tag="{x:Bind RootProcess}"
                                    Visibility="{x:Bind RootProcess.IsEndable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="#F44336" Foreground="White" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon
                                        Glyph="&#xE71A;"
                                        FontFamily="Segoe MDL2 Assets"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Margin="0,0,4,0"/>
                                    <TextBlock Text="End Task"/>
                                </StackPanel>
                            </Button>
                            <Border Visibility="{x:Bind RootProcess.IsProtected, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72E;" FontSize="11"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="System" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Child process rows (shown when expanded) -->
                <ItemsControl ItemsSource="{x:Bind ChildProcesses, Mode=OneWay}"
                              Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessInfo">
                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    MinHeight="40">
                                <Grid HorizontalAlignment="Stretch" Padding="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name (indented) -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                Margin="44,0,0,0" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Description}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind ProcessName}" FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Running time -->
                                    <TextBlock Grid.Column="1" Text="{x:Bind RunningTimeFormatted}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Action -->
                                    <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Click="EndProcess_Click" Tag="{x:Bind}"
                                                Visibility="{x:Bind IsEndable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Background="#F44336" Foreground="White" Padding="12,8">
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon
                                                    Glyph="&#xE71A;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    VerticalAlignment="Center"
                                                    FontSize="15"
                                                    Margin="0,0,4,0"/>
                                                <TextBlock Text="End Task"/>
                                            </StackPanel>
                                        </Button>
                                        <Border Visibility="{x:Bind IsProtected, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="10,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72E;" FontSize="11"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="System" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Header ──────────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Back button -->
                <Button Grid.Row="0" Grid.Column="0"
                        Click="BackButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" Margin="0,0,20,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Monitoring Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Title -->
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8B5;" FontSize="40"
                              Foreground="#9C27B0" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Background Processes"
                               FontSize="36" FontWeight="Bold"
                               TextWrapping="WrapWholeWords" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="View and manage background processes by category"
                           FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="WrapWholeWords" Margin="0,4,0,0"/>

                <!-- View toggle + Refresh -->
                <StackPanel Grid.Row="0" Grid.Column="2"
                            Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                    <!-- Cards / Table toggle -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="3">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Button x:Name="CardViewButton"
                                    Content="Cards" Click="SetCardView_Click"
                                    FontSize="13" Padding="12,7" CornerRadius="6"/>
                            <Button x:Name="TableViewButton"
                                    Content="Table" Click="SetTableView_Click"
                                    FontSize="13" Padding="12,7" CornerRadius="6"/>
                        </StackPanel>
                    </Border>

                    <!-- Refresh -->
                    <Button Command="{x:Bind ViewModel.RefreshCommand}" FontSize="16" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ─── Battery status ───────────────────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="0,0,0,32"
                        Visibility="{x:Bind ViewModel.BatteryDevices.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                <TextBlock Text="🔋 Battery Status" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <ItemsControl ItemsSource="{x:Bind ViewModel.BatteryDevices, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:BatteryInfo">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="2" CornerRadius="12" Padding="20" MinWidth="220">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{x:Bind Icon}" FontFamily="Segoe MDL2 Assets" FontSize="24"/>
                                        <TextBlock Text="{x:Bind DeviceName}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind BatteryLevelFormatted}" FontSize="28" FontWeight="Bold"/>
                                    <ProgressBar Value="{x:Bind BatteryLevel}" Maximum="100" Height="8"/>
                                    <TextBlock Text="{x:Bind Status}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ─── Search bar ────────────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="2" Margin="0,0,0,32">
                <AutoSuggestBox PlaceholderText="Search processes by name or description..."
                                QueryIcon="Find"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" Background="Transparent" BorderThickness="0"/>
            </Border>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!--  CARD VIEW                                                      -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="3" Spacing="48"
                        Visibility="{x:Bind ViewModel.IsCardView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Browsers -->
                <StackPanel Visibility="{x:Bind ViewModel.BrowserProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="🌐 Browsers" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.BrowserProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Gaming -->
                <StackPanel Visibility="{x:Bind ViewModel.GamingProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="🎮 Gaming" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.GamingProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Communication -->
                <StackPanel Visibility="{x:Bind ViewModel.CommunicationProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="💬 Communication" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.CommunicationProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Cloud Storage -->
                <StackPanel Visibility="{x:Bind ViewModel.CloudStorageProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="☁️ Cloud Storage" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.CloudStorageProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Media -->
                <StackPanel Visibility="{x:Bind ViewModel.MediaProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="🎵 Media" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.MediaProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Development -->
                <StackPanel Visibility="{x:Bind ViewModel.DevelopmentProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="💻 Development" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.DevelopmentProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- System Services -->
                <StackPanel Visibility="{x:Bind ViewModel.SystemServicesProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="⚙️ System Services" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SystemServicesProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Other -->
                <StackPanel Visibility="{x:Bind ViewModel.OtherProcesses.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="📦 Other" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.OtherProcesses, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12">
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ProcessGridCardTemplate}" HorizontalContentAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!--  TABLE VIEW                                                     -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="3" Spacing="40"
                        Visibility="{x:Bind ViewModel.IsTableView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Browsers table -->
                <StackPanel Spacing="0"
                            Visibility="{x:Bind ViewModel.BrowserGroups.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                    <TextBlock Text="🌐 Browsers" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="0,6">
                        <Grid Padding="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{x:Bind ViewModel.SortCommand}" CommandParameter="Name"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Padding="4,4">
                                <TextBlock Text="{x:Bind ViewModel.NameHeader, Mode=OneWay}" FontWeight="SemiBold" FontSize="12"/>
                            </Button>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.SortCommand}" CommandParameter="Time"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Padding="4,4">
