<!-- Views/PerformanceTrendsPage.xaml -->
<Page
    x:Class="Winspeqt.Views.Monitoring.PerformanceTrendsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:helpers="using:Winspeqt.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    SizeChanged="ChartsGrid_SizeChanged">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="TrendCardStyle" TargetType="Border" BasedOn="{StaticResource MetricCardBorderStyle}">
            <Setter Property="MinHeight" Value="300"/>
            <Setter Property="MaxHeight" Value="600"/>
        </Style>

        <Style x:Key="TrendCardHeaderIconStyle" TargetType="FontIcon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="TrendCardTitleStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TrendMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TrendMetricSuffixStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,-8,0,16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TrendDetailValueStyle" TargetType="TextBlock" BasedOn="{StaticResource MetricDetailTextStyle}">
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="TrendDetailSecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource TrendDetailValueStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>

        <Style x:Key="TrendChartHostStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="250"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:StandardPageHeader
                Grid.Row="0"
                BackRequested="BackButton_Click"
                BackText="Monitoring Home"
                IconGlyph="&#xE9D9;"
                IconBrush="{StaticResource FeatureSuccessBrush}"
                Title="Resource Trends"
                Subtitle="See what's using your computer's resources over time"
                HeaderMargin="{StaticResource PageHeaderCompactMargin}" />
            <Grid Grid.Row="1" Margin="0,0,0,32" x:Name="ChartsGrid" Loaded="ChartsGrid_Loaded" SizeChanged="ChartsGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ChartsColumn0" Width="*"/>
                    <ColumnDefinition x:Name="ChartsColumn1" Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- CPU Card -->
                <Border 
                    x:Name="CpuCard"
                    Grid.Column="0"
                    Style="{StaticResource TrendCardStyle}"
                    Margin="0,0,12,0"
                    >
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon 
                                Grid.Column="0"
                                Glyph="&#xEC4E;" 
                                Style="{StaticResource TrendCardHeaderIconStyle}"
                                Foreground="{StaticResource FeatureAccentBlueBrush}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="Processor (CPU)"
                                Style="{StaticResource TrendCardTitleStyle}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.TotalCpuUsage, Mode=OneWay}"
                                    Style="{StaticResource TrendMetricValueStyle}"
                                    Foreground="{StaticResource FeatureAccentBlueBrush}"/>
                                <TextBlock
                                    Text="%"
                                    Style="{StaticResource TrendMetricSuffixStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource TrendChartHostStyle}">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.CpuSeries}"
                                YAxes="{x:Bind ViewModel.CpuYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"
                                Background="{StaticResource ChartSurfaceBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="MemoryCard"
                    Grid.Column="1"
                    Style="{StaticResource TrendCardStyle}"
                    Margin="0,0,12,0"
                    >
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon 
                                Grid.Column="0"
                                Glyph="&#xE7F1;" 
                                Style="{StaticResource TrendCardHeaderIconStyle}"
                                Foreground="{StaticResource FeatureAttentionBrush}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="Memory (RAM)"
                                Style="{StaticResource TrendCardTitleStyle}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind ViewModel.MemoryPercent, Mode=OneWay}"
                                    Style="{StaticResource TrendMetricValueStyle}"
                                    Foreground="{StaticResource FeatureAttentionBrush}"/>
                                <TextBlock
                                    Text="%"
                                    Style="{StaticResource TrendMetricSuffixStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource TrendChartHostStyle}">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.MemorySeries}"
                                YAxes="{x:Bind ViewModel.MemoryYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"
                                Background="{StaticResource ChartSurfaceBrush}"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock 
                                Text="{x:Bind ViewModel.CurrentMemory, Mode=OneWay}"
                                Style="{StaticResource TrendDetailValueStyle}"
                                Foreground="{StaticResource FeatureAttentionBrush}" />
                            <TextBlock 
                                Text="MB"
                                Style="{StaticResource TrendDetailValueStyle}"
                                Foreground="{StaticResource FeatureAttentionBrush}" />
                            <TextBlock 
                                Text="/"
                                Style="{StaticResource TrendDetailSecondaryStyle}" />
                            <TextBlock 
                                Text="{x:Bind ViewModel.MaxMemory, Mode=OneWay}"
                                Style="{StaticResource TrendDetailSecondaryStyle}" />
                            <TextBlock 
                                Text="MB"
                                Style="{StaticResource TrendDetailSecondaryStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="NetworkCard"
                    Grid.Column="0"
                    Style="{StaticResource TrendCardStyle}"
                    Margin="0,12,12,0"
                    >
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon 
                                Grid.Column="0"
                                Glyph="&#xE774;" 
                                Style="{StaticResource TrendCardHeaderIconStyle}"
                                Foreground="{StaticResource FeatureSuccessBrush}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="Network"
                                Style="{StaticResource TrendCardTitleStyle}"/>
                            <StackPanel Orientation="Vertical" Grid.Column="2" HorizontalAlignment="Left">
                                    <TextBlock Text="Upload" FontSize="16" />
                                    <StackPanel Orientation="Horizontal">
                                    <TextBlock 
                                        Text="{x:Bind ViewModel.NetworkSentValue, Mode=OneWay}" 
                                        Margin="0,0,4,0" 
                                        Foreground="{StaticResource FeatureSuccessBrush}"
                                        FontSize="20"/>
                                    <TextBlock 
                                        Text="Mbps" 
                                        Foreground="{StaticResource FeatureSuccessBrush}"
                                        FontSize="20" />
                                    </StackPanel>
                                </StackPanel>
                            <StackPanel Orientation="Vertical" Grid.Column="3" HorizontalAlignment="Left">
                                <TextBlock Text="Download" FontSize="16" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock 
                                        Text="{x:Bind ViewModel.NetworkReceivedValue, Mode=OneWay}" 
                                        Margin="0,0,4,0" 
                                        Foreground="{StaticResource FeatureIndigoBrush}"
                                        FontSize="20" />
                                    <TextBlock 
                                        Text="Mbps" 
                                        Foreground="{StaticResource FeatureIndigoBrush}"
                                        FontSize="20" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource TrendChartHostStyle}">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.NetworkSeries}"
                                YAxes="{x:Bind ViewModel.NetworkYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"
                                Background="{StaticResource ChartSurfaceBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="DiskCard"
                    Grid.Column="1"
                    Style="{StaticResource TrendCardStyle}"
                    Margin="12,12,0,0"
                    >
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon 
                                Grid.Column="0"
                                Glyph="&#xE74E;" 
                                Style="{StaticResource TrendCardHeaderIconStyle}"
                                Foreground="{StaticResource FeatureHighlightBrush}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="Disk"
                                Style="{StaticResource TrendCardTitleStyle}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.DiskUsagePercent, Mode=OneWay}"
                                    Style="{StaticResource TrendMetricValueStyle}"
                                    Foreground="{StaticResource FeatureHighlightBrush}"/>    
                                <TextBlock
                                    Text="%"
                                    Style="{StaticResource TrendMetricSuffixStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource TrendChartHostStyle}">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.DiskSeries}"
                                YAxes="{x:Bind ViewModel.DiskYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"
                                Background="{StaticResource ChartSurfaceBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Loading Overlay -->
            <Border
                Grid.Row="0" 
                Grid.RowSpan="3"
                Style="{StaticResource LoadingOverlayBorderStyle}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing 
                        IsActive="True"
                        Width="80"
                        Height="80"/>
                    <TextBlock 
                        Text="Loading system information..."
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
