<!-- Views/PerformanceTrendsPage.xaml -->
<Page
    x:Class="Winspeqt.Views.Monitoring.PerformanceTrendsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:helpers="using:Winspeqt.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button 
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="BackButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Monitoring Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Grid
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,4"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        Glyph="&#xE9D9;"
                        FontSize="40"
                        Foreground="#4CAF50"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1"
                        Text="Resource Trends" 
                        FontSize="36" 
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords"
                        VerticalAlignment="Center"/>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="See what's using your computer's resources over time"
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords"
                    Margin="0,4,0,0"/>

                <!--<Button 
                    Grid.Row="0"
                    Grid.Column="2"
                    Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    FontSize="16"
                    Padding="16,8"/>-->
            </Grid>
            <Grid Grid.Row="1" Margin="0,0,0,32" x:Name="ChartsGrid" Loaded="ChartsGrid_Loaded" SizeChanged="ChartsGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ChartsColumn0" Width="*"/>
                    <ColumnDefinition x:Name="ChartsColumn1" Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- CPU Card -->
                <Border 
                    x:Name="CpuCard"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,0,12,0"
                    MinHeight="300"
                    MaxHeight="600">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xEC4E;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#2196F3"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Processor (CPU)"
                                VerticalAlignment="Center"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>
                        <Border
                            MinHeight="250">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.CpuSeries}"
                                YAxes="{x:Bind ViewModel.CpuYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="MemoryCard"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,0,12,0"
                    MinHeight="300"
                    MaxHeight="600">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE7F1;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#FF9800"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Memory (RAM)"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>
                        <Border
                            MinHeight="250">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.MemorySeries}"
                                YAxes="{x:Bind ViewModel.MemoryYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="NetworkCard"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,12,12,0"
                    MinHeight="300"
                    MaxHeight="600">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE774;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#4CAF50"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Network"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>
                        <Border
                            MinHeight="250">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.NetworkSeries}"
                                YAxes="{x:Bind ViewModel.NetworkYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"
                                LegendPosition="Top"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border 
                    x:Name="DiskCard"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="28"
                    Margin="12,12,0,0"
                    MinHeight="300"
                    MaxHeight="600">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon 
                                Glyph="&#xE74E;" 
                                FontFamily="Segoe MDL2 Assets" 
                                VerticalAlignment="Center"
                                Foreground="#9C27B0"
                                FontWeight="SemiBold"
                                FontSize="20"
                                Margin="0,0,4,16"/>
                            <TextBlock
                                Text="Disk"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16"/>
                        </StackPanel>
                        <Border
                            MinHeight="250">
                            <lvc:CartesianChart
                                Series="{x:Bind ViewModel.DiskSeries}"
                                YAxes="{x:Bind ViewModel.DiskYAxes}"
                                XAxes="{x:Bind ViewModel.XAxes}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Loading Overlay -->
            <Border
                Grid.Row="0" 
                Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing 
                        IsActive="True"
                        Width="80"
                        Height="80"/>
                    <TextBlock 
                        Text="Loading system information..."
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
