<Page
    x:Class="Winspeqt.Views.Monitoring.MonitoringDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="{StaticResource DashboardPagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:StandardDashboardHeader
                Grid.Row="0"
                BackRequested="BackButton_Click"
                IconGlyph="&#xE9D9;"
                IconBrush="{StaticResource FeatureAttentionBrush}"
                Title="System Monitoring"
                Subtitle="Understand what's slowing your PC down in plain English" />

            <Grid Grid.Row="2" Margin="{StaticResource DashboardFeatureGridMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardTopLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="TaskManagerCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE7C4;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAttentionBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Friendly Task Manager" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="See which apps are using CPU, RAM, Disk, and Network with easy-to-understand explanations" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Open Task Manager" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardTopRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="ResourceTrendsCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE9D9;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureSuccessBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Resource Trends" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="View graphs showing how your CPU, memory, and disk usage change over time" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="View Trends" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardBottomLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="StartupImpactCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE7E8;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAccentBlueBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="What's Slowing Down My PC?" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Find and fix common reasons your PC feels sluggish &#x2014; check startup apps, restart File Explorer, test your network speed, and more" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Diagnose My PC" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardBottomRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="BackgroundProcessCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE8B5;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureHighlightBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Background Process Insights" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Discover hidden apps running in the background that use significant resources" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="View Processes" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
