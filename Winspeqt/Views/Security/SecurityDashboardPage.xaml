<Page
    x:Class="Winspeqt.Views.Security.SecurityDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <ScrollViewer>
        <Grid Padding="{StaticResource DashboardPagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:StandardDashboardHeader
                Grid.Row="0"
                BackRequested="BackButton_Click"
                IconGlyph="&#xE72E;"
                IconBrush="{StaticResource FeatureSuccessBrush}"
                Title="Device Hardening &amp; Security"
                Subtitle="Make your system safer without needing technical knowledge" />

            <Grid Grid.Row="2" Margin="{StaticResource DashboardFeatureGridMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardTopLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="SecurityStatusCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE72E;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureSuccessBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Security Status Dashboard" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Monitor your PC's security at a glance and spot anything that needs attention" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Check Status" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardTopRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="AppSecurityScannerCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE7BA;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureCriticalBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="App Update Checker" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Discover outdated apps on your PC and update them right from this page" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Scan Apps" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardBottomLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="NetworkSecurityCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE968;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAccentBlueBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Network Security Monitor" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="See what's connecting to the internet from your PC and detect suspicious network activity" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Monitor Network" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardBottomRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="SettingsRecommendationsCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE713;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAttentionBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Windows Settings Recommendations" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Learn about security settings like SmartScreen, remote access, and privacy options explained in plain language" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="View Settings" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
