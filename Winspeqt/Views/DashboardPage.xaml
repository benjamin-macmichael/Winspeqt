<Page
    x:Class="Winspeqt.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:StringToBrushConverter x:Key="StringToBrushConverter" />
    </Page.Resources>

    <Grid x:Name="RootLayout">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="NarrowState" />
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <!-- Keep in sync with ApplyResponsiveState() in code-behind. -->
                        <AdaptiveTrigger MinWindowWidth="{StaticResource DashboardWideMinWidth}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CardsColumn0.Width" Value="*" />
                        <Setter Target="CardsColumn1.Width" Value="*" />
                        <Setter Target="CardsColumn2.Width" Value="*" />
                        <Setter Target="CardsRow0.Height" Value="Auto" />
                        <Setter Target="CardsRow1.Height" Value="0" />
                        <Setter Target="CardsRow2.Height" Value="0" />
                        <Setter Target="SecurityCard.(Grid.Row)" Value="1" />
                        <Setter Target="SecurityCard.(Grid.Column)" Value="0" />
                        <Setter Target="SecurityCard.Margin" Value="0,0,20,0" />
                        <Setter Target="OptimizationCard.(Grid.Row)" Value="1" />
                        <Setter Target="OptimizationCard.(Grid.Column)" Value="1" />
                        <Setter Target="OptimizationCard.Margin" Value="20,0" />
                        <Setter Target="MonitoringCard.(Grid.Row)" Value="1" />
                        <Setter Target="MonitoringCard.(Grid.Column)" Value="2" />
                        <Setter Target="MonitoringCard.Margin" Value="20,0,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" Padding="{StaticResource DashboardHeroHeaderPadding}">
            <TextBlock Text="Winspeqt" Style="{StaticResource DashboardHeroTitleTextStyle}" />
            <TextBlock Text="Your Windows System Inspector and Optimizer" Style="{StaticResource DashboardHeroSubtitleTextStyle}" />
            <TextBlock Text="Choose a category to get started" Style="{StaticResource DashboardHeroCaptionTextStyle}" />
        </StackPanel>

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">
            <Grid Padding="{StaticResource DashboardContentPadding}" MaxWidth="{StaticResource DashboardMaxWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CardsColumn0" Width="*" />
                    <ColumnDefinition x:Name="CardsColumn1" Width="0" />
                    <ColumnDefinition x:Name="CardsColumn2" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="CardsRow0" Height="Auto" />
                    <RowDefinition x:Name="CardsRow1" Height="Auto" />
                    <RowDefinition x:Name="CardsRow2" Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource DashboardSummaryCardBorderStyle}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="System Health" Style="{StaticResource DashboardSummaryTitleTextStyle}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Style="{StaticResource DashboardMetricButtonStyle}"
                                Command="{Binding SecurityScoreCommand}">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <Grid Width="{StaticResource DashboardMetricSize}" Height="{StaticResource DashboardMetricSize}" HorizontalAlignment="Center">
                                        <ProgressRing
                                            Width="{StaticResource DashboardMetricSize}"
                                            Height="{StaticResource DashboardMetricSize}"
                                            IsIndeterminate="False"
                                            Value="{Binding SecurityScore}"
                                            Maximum="100"
                                            Foreground="{Binding SecurityScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                                        <TextBlock
                                            Text="{Binding SecurityScoreText}"
                                            Style="{StaticResource DashboardMetricValueTextStyle}"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="Security Score" Style="{StaticResource DashboardMetricLabelTextStyle}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="1"
                                Style="{StaticResource DashboardMetricButtonStyle}"
                                Command="{Binding DiskCommand}">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <Grid Width="{StaticResource DashboardMetricSize}" Height="{StaticResource DashboardMetricSize}" HorizontalAlignment="Center">
                                        <ProgressRing
                                            Width="{StaticResource DashboardMetricSize}"
                                            Height="{StaticResource DashboardMetricSize}"
                                            IsIndeterminate="False"
                                            Value="{Binding DiskPercent}"
                                            Maximum="100"
                                            Foreground="{Binding DiskColor, Converter={StaticResource StringToBrushConverter}}" />
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding DiskCenterText}" Style="{StaticResource DashboardMetricValueTextStyle}" />
                                            <TextBlock Text="{Binding DiskSubText}" Style="{StaticResource DashboardMetricSupportingTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Total Memory" Style="{StaticResource DashboardMetricLabelTextStyle}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="2"
                                Style="{StaticResource DashboardMetricButtonStyle}"
                                Command="{Binding RamCommand}">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <Grid Width="{StaticResource DashboardMetricSize}" Height="{StaticResource DashboardMetricSize}" HorizontalAlignment="Center">
                                        <ProgressRing
                                            Width="{StaticResource DashboardMetricSize}"
                                            Height="{StaticResource DashboardMetricSize}"
                                            IsIndeterminate="False"
                                            Value="{Binding RamPercent}"
                                            Maximum="100"
                                            Foreground="{Binding RamColor, Converter={StaticResource StringToBrushConverter}}" />
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding RamCenterText}" Style="{StaticResource DashboardMetricValueTextStyle}" />
                                            <TextBlock Text="{Binding RamSubText}" Style="{StaticResource DashboardMetricSupportingTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="RAM Usage" Style="{StaticResource DashboardMetricLabelTextStyle}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="SecurityCard"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,20"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Command="{Binding SecurityCommand}">
                    <Grid Padding="{StaticResource DashboardCategoryCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE72E;"
                            FontSize="64"
                            Foreground="{StaticResource FeatureSuccessBrush}"
                            HorizontalAlignment="Center"
                            Margin="{StaticResource DashboardCategoryCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Security" Style="{StaticResource DashboardCategoryCardTitleTextStyle}" />
                            <TextBlock Text="Stay protected with tools that cover status, apps, network, and settings" Style="{StaticResource DashboardCategoryCardBodyTextStyle}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Row="2"
                            Text="Get Started &#x2192;"
                            Style="{StaticResource DashboardCategoryCardCtaTextStyle}" />
                    </Grid>
                </Button>

                <Button
                    x:Name="OptimizationCard"
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,0,20"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Command="{Binding OptimizationCommand}">
                    <Grid Padding="{StaticResource DashboardCategoryCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xEC4A;"
                            FontSize="64"
                            Foreground="{StaticResource FeatureAccentBlueBrush}"
                            HorizontalAlignment="Center"
                            Margin="{StaticResource DashboardCategoryCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Optimization" Style="{StaticResource DashboardCategoryCardTitleTextStyle}" />
                            <TextBlock Text="Free up disk space, find large files, remove unused apps, and speed up your system safely" Style="{StaticResource DashboardCategoryCardBodyTextStyle}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Row="2"
                            Text="Get Started &#x2192;"
                            Style="{StaticResource DashboardCategoryCardCtaTextStyle}" />
                    </Grid>
                </Button>

                <Button
                    x:Name="MonitoringCard"
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="0"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Command="{Binding MonitoringCommand}">
                    <Grid Padding="{StaticResource DashboardCategoryCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE9D9;"
                            FontSize="64"
                            Foreground="{StaticResource FeatureAttentionBrush}"
                            HorizontalAlignment="Center"
                            Margin="{StaticResource DashboardCategoryCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Monitoring" Style="{StaticResource DashboardCategoryCardTitleTextStyle}" />
                            <TextBlock Text="Monitor CPU, memory, and disk usage in real-time with friendly explanations of what's happening" Style="{StaticResource DashboardCategoryCardBodyTextStyle}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Row="2"
                            Text="Get Started &#x2192;"
                            Style="{StaticResource DashboardCategoryCardCtaTextStyle}" />
                    </Grid>
                </Button>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
