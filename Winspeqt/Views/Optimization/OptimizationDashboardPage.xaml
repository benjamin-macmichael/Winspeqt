<Page
    x:Class="Winspeqt.Views.Optimization.OptimizationDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="{StaticResource DashboardPagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:StandardDashboardHeader
                Grid.Row="0"
                BackRequested="BackButton_Click"
                IconGlyph="&#xEC4A;"
                IconBrush="{StaticResource FeatureAccentBlueBrush}"
                Title="System Optimization &amp; Cleanup"
                Subtitle="Free up space and improve performance safely" />

            <Grid Grid.Row="2" Margin="{StaticResource DashboardFeatureGridMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                    <RowDefinition Height="*" MinHeight="{StaticResource DashboardFeatureCardMinHeight}" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardTopLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="LargeFileFinderCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE8B7;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureCriticalBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Large File Finder" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Scan your folders to find the largest files taking up space on your PC" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Find Large Files" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardTopRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="AppUsageTrackerCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE74C;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAccentBlueBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="App Usage Tracker" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Track your screen-time across apps, and see how long apps have been unused." Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="View Apps" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="{StaticResource DashboardFeatureCardBottomLeftMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="AppDataCleanupCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE74D;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureAttentionBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Safe AppData Cleanup" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Identify and remove outdated cache, temp files, and unneeded data safely" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Start Cleanup" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="{StaticResource DashboardFeatureCardBottomRightMargin}"
                    Style="{StaticResource DashboardCardButtonStyle}"
                    Click="OneClickOptimizationCard_Click">
                    <Grid Padding="{StaticResource DashboardFeatureCardPadding}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <FontIcon
                            Grid.Row="0"
                            Glyph="&#xE73C;"
                            FontSize="56"
                            Foreground="{StaticResource FeatureSuccessBrush}"
                            Margin="{StaticResource DashboardFeatureCardIconMargin}" />

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="One-Click Optimization" Style="{StaticResource DashboardFeatureCardTitleTextStyle}" />
                            <TextBlock Text="Run a complete cleanup: temp files, recycle bin, logs, and more in one click" Style="{StaticResource DashboardFeatureCardBodyTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource DashboardFeatureCardCtaMargin}" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Optimize Now" Style="{StaticResource DashboardFeatureCardCtaTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
