<Page
    x:Class="Winspeqt.Views.Optimization.AppUsagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:local="using:Winspeqt.Views.Optimization"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:FirstLetterConverter x:Key="FirstLetterConverter"/>
        <local:TrackingButtonTextConverter x:Key="TrackingButtonTextConverter"/>

        <Style x:Key="AppUsageStatCardStyle" TargetType="Border" BasedOn="{StaticResource StandardCardBorderStyle}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="AppUsageListCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardBorderStyle}">
            <Setter Property="Padding" Value="15"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="AppUsagePrimaryActionStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}"/>

        <Style x:Key="AppUsageNeutralActionStyle" TargetType="Button" BasedOn="{StaticResource SecondaryOutlineActionButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid Visibility="{Binding ShowInstalledAppsView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:StandardPageHeader
                Grid.Row="0"
                Margin="30,30,30,0"
                BackText="Optimization Home"
                BackRequested="BackButton_Click"
                IconGlyph="&#xE74C;"
                IconBrush="{StaticResource FeatureAccentBlueBrush}"
                Title="App Usage Tracker"
                Subtitle="Monitor your application usage and screen time"
                HeaderMargin="0,0,0,20" />

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        Margin="30,0,30,20">
                <Button Content="View Installed Apps"
                        Command="{Binding ShowInstalledAppsCommand}"
                        Style="{StaticResource AppUsagePrimaryActionStyle}"/>

                <Button Content="{Binding IsTrackingEnabled, Converter={StaticResource TrackingButtonTextConverter}}"
                        Command="{Binding ToggleTrackingCommand}"
                        Style="{StaticResource AppUsagePrimaryActionStyle}"
                        Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource AppUsageNeutralActionStyle}"
                        Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="Reset"
                        Command="{Binding ResetTrackingCommand}"
                        Style="{StaticResource DangerActionButtonStyle}"
                        Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="30,0,30,20"
                    Visibility="{Binding HasOptedIn, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Border Style="{StaticResource StandardCardBorderStyle}"
                        Padding="30,24"
                        BorderBrush="{StaticResource ActionPrimaryBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                            <FontIcon Glyph="&#xE9D2;" FontSize="24" Foreground="{StaticResource ActionPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Enable App Usage Tracking"
                                       Style="{StaticResource SectionHeadingTextStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16">
                            <Run Text="Track which applications you use and for how long. This helps you understand your productivity patterns and identify apps you might want to uninstall."/>
                        </TextBlock>

                        <Border Grid.Row="2"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                CornerRadius="6"
                                Padding="16,12"
                                Margin="0,0,0,20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🔒 Your Privacy"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FeatureSuccessBrush}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="• All data stays on YOUR computer"/>
                                    <LineBreak/>
                                    <Run Text="• Nothing is sent to Winspeqt or any servers"/>
                                    <LineBreak/>
                                    <Run Text="• You can disable tracking at any time"/>
                                    <LineBreak/>
                                    <Run Text="• You can reset/delete all tracked data anytime"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="3"
                                Content="✓ Enable App Usage Tracking"
                                Command="{Binding OptInCommand}"
                                Style="{StaticResource AppUsagePrimaryActionStyle}"
                                Padding="32,14"
                                FontSize="16"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </Border>

            <Grid Grid.Row="2"
                  Padding="30,0,30,20"
                  Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppUsageStatCardStyle}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Total Screen Time" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalScreenTimeFormatted}" Style="{StaticResource MetricValueTextStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppUsageStatCardStyle}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Apps Used" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.TotalAppsUsed}" Style="{StaticResource MetricValueTextStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AppUsageStatCardStyle}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Currently Active" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.ActiveApps}" Style="{StaticResource MetricValueTextStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource AppUsageStatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Most Used App" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.MostUsedApp}"
                                FontSize="18"
                                FontWeight="Bold"
                                TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    Style="{StaticResource AppUsageListCardStyle}"
                    Margin="30,0,30,20"
                    Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search applications..."
                         Background="Transparent"
                         Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                         BorderThickness="0"
                         FontSize="14"
                         VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer Grid.Row="4"
                          Margin="30,0,30,30"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Applications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppUsageListCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource ActionPrimaryBrush}"
                                            CornerRadius="8"
                                            Width="50"
                                            Height="50"
                                            Margin="0,0,15,0">
                                        <TextBlock Text="{Binding AppName, Converter={StaticResource FirstLetterConverter}}"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding AppName}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <Border Background="{StaticResource ActionPrimaryBrush}"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Running"
                                                           Foreground="White"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Margin="0,3,0,0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,3,0,0">
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Last used:"/>
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding FormattedLastUsed}"/>
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•"/>
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Launched"/>
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding LaunchCount}"/>
                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="times"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,30,0">
                                        <TextBlock Text="{Binding FormattedUsageTime}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="Total Time"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Foreground="{StaticResource ActionPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding FormattedUsagePercentage}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding UsagePercentage}"
                                                     Maximum="100"
                                                     Width="60"
                                                     Height="6"
                                                     Margin="0,5,0,0"
                                                     Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                     Foreground="{StaticResource ActionPrimaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Visibility="{Binding ShowInstalledAppsView, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="30,20,30,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:StandardPageHeader
                    Grid.Row="0"
                    BackText="Usage Tracker"
                    BackRequested="InstalledBackButton_Click"
                    IconGlyph="&#xE8D6;"
                    IconBrush="{StaticResource ActionPrimaryBrush}"
                    Title="Installed Applications"
                    Subtitle="Find apps you haven't used recently and consider uninstalling"
                    HeaderMargin="0,0,0,0" />

                <Border Grid.Row="1"
                        Style="{StaticResource AppUsageListCardStyle}"
                        Margin="0,20,0,0"
                        Padding="20,15">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{StaticResource ActionPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center">
                            <Run Text="Usage history is based on Winspeqt's tracking. The longer you use Winspeqt, the more useful this data becomes."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="30,0,30,30"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding InstalledApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppUsageListCardStyle}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AppName}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <TextBlock Text="Last Used" Style="{StaticResource CaptionTextStyle}"/>
                                        <TextBlock Text="{Binding FormattedLastUsed}" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Style="{StaticResource LoadingOverlayBorderStyle}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressRing IsActive="True" Width="50" Height="50" Foreground="White"/>
                <TextBlock Text="Loading..."
                           Foreground="White"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
