<Page
    x:Class="Winspeqt.Views.Optimization.AppUsagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winspeqt.Views.Optimization"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:FirstLetterConverter x:Key="FirstLetterConverter"/>
        <local:TrackingButtonTextConverter x:Key="TrackingButtonTextConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Usage Tracking View -->
        <Grid Visibility="{Binding ShowInstalledAppsView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="30,30,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button 
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="BackButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Padding="8"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Optimization Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,0,0,4"
                    VerticalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE74C;"
                        FontSize="40"
                        Foreground="#2196F3"
                        VerticalAlignment="Center"/>
                    <TextBlock
                        Text="App Usage Tracker" 
                        FontSize="36" 
                        FontWeight="Bold" 
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Monitor your application usage and screen time"
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,4,0,0"/>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Button Content="View Installed Apps" 
                            Command="{Binding ShowInstalledAppsCommand}"
                            Background="#007ACC"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"/>

                    <Button Content="{Binding IsTrackingEnabled, Converter={StaticResource TrackingButtonTextConverter}}" 
                            Command="{Binding ToggleTrackingCommand}"
                            Background="#007ACC"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"
                            Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="Refresh" 
                            Command="{Binding RefreshCommand}"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Padding="20,10"
                            CornerRadius="6"
                            Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="Reset" 
                            Command="{Binding ResetTrackingCommand}"
                            Background="#BC2F32"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"
                            Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

            <!-- Opt-in Banner (shown only before user has ever opted in) -->
            <Border Grid.Row="1" 
                    Padding="30,0,30,20"
                    Visibility="{Binding HasOptedIn, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" 
                        Padding="30,24"
                        BorderBrush="#007ACC"
                        BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                            <FontIcon Glyph="&#xE9D2;" FontSize="24" Foreground="#007ACC" VerticalAlignment="Center"/>
                            <TextBlock Text="Enable App Usage Tracking"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16">
                            <Run Text="Track which applications you use and for how long. This helps you understand your productivity patterns and identify apps you might want to uninstall."/>
                        </TextBlock>

                        <Border Grid.Row="2"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                CornerRadius="6"
                                Padding="16,12"
                                Margin="0,0,0,20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🔒 Your Privacy" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="#16C60C"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="• All data stays on YOUR computer"/>
                                    <LineBreak/>
                                    <Run Text="• Nothing is sent to Winspeqt or any servers"/>
                                    <LineBreak/>
                                    <Run Text="• You can disable tracking at any time"/>
                                    <LineBreak/>
                                    <Run Text="• You can reset/delete all tracked data anytime"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="3"
                                Content="✓ Enable App Usage Tracking"
                                Command="{Binding OptInCommand}"
                                Background="#007ACC"
                                Foreground="White"
                                Padding="32,14"
                                FontSize="16"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Stats Cards (hidden until opted in) -->
            <Grid Grid.Row="1" Padding="30,0,30,20"
                  Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Total Screen Time" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalScreenTimeFormatted}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Apps Used" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.TotalAppsUsed}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Currently Active" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.ActiveApps}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Most Used App" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding UsageStats.MostUsedApp}" 
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Search Bar (hidden until opted in) -->
            <Border Grid.Row="2" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="6" 
                    Margin="30,0,30,20"
                    Padding="15,10"
                    Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search applications..."
                         Background="Transparent"
                         Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                         BorderThickness="0"
                         FontSize="14"
                         VerticalAlignment="Center"/>
            </Border>

            <!-- Applications List (hidden until opted in) -->
            <ScrollViewer Grid.Row="3" 
                          Margin="30,0,30,30"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasOptedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Applications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    CornerRadius="6" 
                                    Padding="15" 
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- App Icon -->
                                    <Border Grid.Column="0" 
                                            Background="#007ACC" 
                                            CornerRadius="8" 
                                            Width="50" 
                                            Height="50"
                                            Margin="0,0,15,0">
                                        <TextBlock Text="{Binding AppName, Converter={StaticResource FirstLetterConverter}}" 
                                                   Foreground="White" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- App Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding AppName}" 
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       FontSize="16" 
                                                       FontWeight="SemiBold"/>
                                            <Border Background="#007ACC" 
                                                    CornerRadius="10" 
                                                    Padding="8,2"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Running" 
                                                           Foreground="White" 
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ProcessName}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   FontSize="12" 
                                                   Margin="0,3,0,0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,3,0,0">
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="Last used:"/>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="{Binding FormattedLastUsed}"/>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="•"/>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="Launched"/>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="{Binding LaunchCount}"/>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="times"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Usage Time -->
                                    <StackPanel Grid.Column="2" 
                                                VerticalAlignment="Center" 
                                                HorizontalAlignment="Right"
                                                Margin="0,0,30,0">
                                        <TextBlock Text="{Binding FormattedUsageTime}" 
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="Total Time" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Usage Percentage -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Foreground="#007ACC" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding FormattedUsagePercentage}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding UsagePercentage}" 
                                                     Maximum="100"
                                                     Width="60"
                                                     Height="6"
                                                     Margin="0,5,0,0"
                                                     Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                     Foreground="#007ACC"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Installed Apps View -->
        <Grid Visibility="{Binding ShowInstalledAppsView, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Installed Apps Header -->
            <Grid Grid.Row="0" Padding="30,20,30,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Grid.Row="0"
                        Visibility="Collapsed"
                        Content="← Back"
                        Command="{Binding ShowUsageViewCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        FontSize="16"
                        Padding="8"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="0"
                        Grid.Row="0"
                        Command="{Binding ShowUsageViewCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Usage View" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel
                    Grid.Column="1"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,0,0,4"
                    VerticalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="40"
                        Foreground="#007ACC"
                        VerticalAlignment="Center"/>
                    <TextBlock
                        Text="Installed Applications"
                        FontSize="36"
                        FontWeight="Bold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    Grid.Row="1"
                    Text="Find apps you haven't used recently and consider uninstalling"
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,4,0,0"/>

                <Border Grid.Row="1" 
                        Grid.ColumnSpan="2" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="6" 
                        Padding="20,15"
                        Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="#007ACC" VerticalAlignment="Center"/>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center">
                                <Run Text="Usage history is based on Winspeqt's tracking. The longer you use Winspeqt, the more useful this data becomes."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Installed Apps List -->
            <ScrollViewer Grid.Row="1" 
                          Margin="30,0,30,30"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding InstalledApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    CornerRadius="6" 
                                    Padding="15" 
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- App Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AppName}" 
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Last Used -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <TextBlock Text="Last Used" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10"/>
                                        <TextBlock Text="{Binding FormattedLastUsed}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Background="#CC000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressRing IsActive="True" Width="50" Height="50" Foreground="White"/>
                <TextBlock Text="Loading..." 
                           Foreground="White" 
                           FontSize="20" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
