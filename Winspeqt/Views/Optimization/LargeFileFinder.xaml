<Page
    x:Class="Winspeqt.Views.Optimization.LargeFileFinder"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pageControls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:optimization="using:Winspeqt.ViewModels.Optimization"
    d:DataContext="{d:DesignInstance Type=optimization:LargeFileFinderViewModel}"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:FolderItemTypeToGlyphConverter x:Key="FolderItemTypeToGlyphConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
        <helpers:BoolInverter x:Key="BoolInverter"/>

        <x:Double x:Key="LargeFileFinderContentWidth">750</x:Double>

        <Style x:Key="FinderHelpButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryOutlineActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>

        <Style x:Key="FinderSeparatorStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <pageControls:StandardPageHeader
                Grid.Row="0"
                BackText="Optimization Home"
                BackRequested="BackButton_Click"
                IconGlyph="&#xE8B7;"
                IconBrush="{StaticResource FeatureCriticalBrush}"
                Title="Large File Finder"
                Subtitle="Scan your folders to find the largest files taking up space on your PC"
                HeaderMargin="{StaticResource PageHeaderCompactMargin}" />

            <StackPanel Grid.Row="1" MaxWidth="{StaticResource LargeFileFinderContentWidth}">
                <toolkit:WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Hidden files" Style="{StaticResource FinderHelpButtonStyle}">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MaxHeight="340">
                                    <StackPanel MaxWidth="340" Spacing="8" Padding="6">
                                        <TextBlock
                                            Text="You may see some files here that you don't see in File Explorer. That is normal. Some files are hidden by default."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Hidden files are system or app files that Windows hides by default to keep important files out of the way. Their names often start with a period."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Hidden files can include configuration data and critical OS files. While it is okay to delete some hidden files to free up space, you should always exercise caution when doing so."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="To show hidden files in File Explorer, click on the button labeled 'View'. From the dropdown, select 'Show' and then select 'Hidden items'."
                                            TextWrapping="WrapWholeWords"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Deleting files safely" Style="{StaticResource FinderHelpButtonStyle}">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MaxHeight="340">
                                    <StackPanel MaxWidth="340" Spacing="8" Padding="6">
                                        <TextBlock
                                            Text="Be careful when deleting files because some files are required by Windows or installed apps. When possible, it is better to uninstall an app rather than just delete its files."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="If you are unsure, verify the file path or move files to Recycle Bin first instead of permanent deletion."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Alternatively, try using the Safe AppData Cleanup or One-Click Optimization in Winspeqt to safely free up space on your computer."
                                            TextWrapping="WrapWholeWords"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </toolkit:WrapPanel>

                <TextBlock FontSize="18" Margin="0,0,0,16" TextWrapping="WrapWholeWords">
                    <Run Text="You are using "/>
                    <Run Text="{x:Bind ViewModel.DriveUsageHighlight, Mode=OneWay}"
                         Foreground="{x:Bind ViewModel.DriveUsageColor, Mode=OneWay}"
                         FontWeight="SemiBold"/>
                    <Run Text="{x:Bind ViewModel.DriveUsageSuffix, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    FontSize="18"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource SystemErrorTextColor}"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Center"/>

                <StackPanel
                    Orientation="Horizontal"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    MaxWidth="{StaticResource LargeFileFinderContentWidth}"
                    HorizontalAlignment="Center"
                    Padding="0,0,0,25">
                    <TextBlock
                        Text="Calculating folder sizes. This may take a moment."
                        FontSize="20"
                        TextWrapping="WrapWholeWords"
                        HorizontalAlignment="Stretch"/>
                    <ProgressRing
                        IsActive="True"
                        Width="20"
                        Height="20" />
                </StackPanel>

                <Grid MaxWidth="{StaticResource LargeFileFinderContentWidth}" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock
                            Text="Sort by:"
                            FontSize="16"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,12,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ComboBox
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            MinWidth="150"
                            FontSize="15"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                        <Button
                            Click="Refresh_Click"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                        <Button
                            Content="View Folder in File Explorer"
                            Click="ViewFileExplorer_Click"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <ListView ItemsSource="{Binding PathItems, Mode=OneWay}"
                          MaxWidth="{StaticResource LargeFileFinderContentWidth}"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,7"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="/" FontSize="24" Opacity="{Binding ElementName=RootPage, Path=ViewModel.FolderItemOpacity}" />
                                <Button
                                    Click="BreadCrumb_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    CommandParameter="{Binding Index}"
                                    IsEnabled="{Binding ElementName=RootPage, Path=ViewModel.IsLoading, Converter={StaticResource BoolInverter}}">
                                    <TextBlock Text="{Binding Name}" FontSize="24" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Rectangle Height="2"
                           Width="{StaticResource LargeFileFinderContentWidth}"
                           Style="{StaticResource FinderSeparatorStyle}"/>

                <ItemsRepeater ItemsSource="{Binding ActiveNode.Children, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Button
                                    Click="Folder_Click"
                                    CommandParameter="{Binding FilePath}"
                                    MaxWidth="{StaticResource LargeFileFinderContentWidth}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,8"
                                    Opacity="{Binding ElementName=RootPage, Path=ViewModel.FolderItemOpacity}"
                                    IsEnabled="{Binding ElementName=RootPage, Path=ViewModel.IsLoading, Converter={StaticResource BoolInverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                            <FontIcon
                                                Glyph="{Binding Type, Converter={StaticResource FolderItemTypeToGlyphConverter}}"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                            <TextBlock
                                                Text="{Binding Name}"
                                                FontSize="24"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding Finished, Mode=OneWay, Converter={StaticResource BoolToCollapsedConverter}}">
                                            <ProgressRing
                                                IsActive="True"
                                                Width="10"
                                                Height="10" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding Finished, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock
                                                Text="{Binding Size}"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                            <TextBlock
                                                Text="{Binding DataLabel}"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Rectangle Height="1"
                                           Width="{StaticResource LargeFileFinderContentWidth}"
                                           Style="{StaticResource FinderSeparatorStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
