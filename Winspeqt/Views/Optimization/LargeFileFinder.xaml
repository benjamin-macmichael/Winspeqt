<Page
    x:Class="Winspeqt.Views.Optimization.LargeFileFinder"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winspeqt.Views.Optimization"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers" 
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:optimization="using:Winspeqt.ViewModels.Optimization" d:DataContext="{d:DesignInstance Type=optimization:LargeFileFinderViewModel}"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Converters used by item icons, loading visibility, and list interactivity. -->
        <helpers:FolderItemTypeToGlyphConverter x:Key="FolderItemTypeToGlyphConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
        <helpers:BoolInverter x:Key="BoolInverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button 
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="BackButton_Click"
                    Margin="0,0,20,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Optimization Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,0,0,4"
                    VerticalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE8B7;"
                        FontSize="40"
                        Foreground="#F44336"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Text="Large File Finder" 
                        FontSize="36" 
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Scan your folders to find the largest files taking up space on your PC"
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,4,0,0"
                    TextWrapping="WrapWholeWords"/>
            </Grid>
            <StackPanel Grid.Row="1" MaxWidth="750">
                <TextBlock FontSize="18" Margin="0,0,0,8" TextWrapping="WrapWholeWords">
                    <Run Text="You are using "/>
                    <Run Text="{x:Bind ViewModel.DriveUsageHighlight, Mode=OneWay}"
                         Foreground="{x:Bind ViewModel.DriveUsageColor, Mode=OneWay}"
                         FontWeight="SemiBold"/>
                    <Run Text="{x:Bind ViewModel.DriveUsageSuffix, Mode=OneWay}"/>
                </TextBlock>
                <controls:WrapPanel
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
                    <Button Content="Hidden files" Margin="0,0,10,10">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MaxHeight="340">
                                    <StackPanel MaxWidth="340" Spacing="8" Padding="6">
                                        <TextBlock 
                                            Text="You may see some files here that you don't see in File Explorer. That is normal. Some files are hidden by default."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Hidden files are system or app files that Windows hides by default to keep important files out of the way. Their names often start with a period."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Hidden files can include configuration data and critical OS files. While it is okay to delete some hidden files to free up space, you should always exercise caution when doing so."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="To show hidden files in File Explorer, click on the button labeled 'View'. From the dropdown, select 'Show' and then select 'Hidden items'."
                                            TextWrapping="WrapWholeWords"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Deleting files safely" Margin="0,0,10,10">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ScrollViewer MaxHeight="340">
                                    <StackPanel MaxWidth="340" Spacing="8" Padding="6">
                                        <TextBlock
                                            Text="Be careful when deleting files because some files are required by Windows or installed apps. When possible, it is better to unistall an app rather than just delete its files."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="If you are unsure, verify the file path or move files to Recycle Bin first instead of permanent deletion."
                                            TextWrapping="WrapWholeWords"/>
                                        <TextBlock
                                            Text="Alternatively, try using the Safe AppData Cleanup or One-Click Optimization in Winspeqt to safely free up space on your computer."
                                            TextWrapping="WrapWholeWords"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </controls:WrapPanel>
                <!-- Global status area for blocking errors and background-loading state. -->
                <TextBlock
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    FontSize="18"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource SystemErrorTextColor}"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Center"
                    />
                <StackPanel 
                    Orientation="Horizontal"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    MaxWidth="750"
                    HorizontalAlignment="Center"
                    Padding="0,0,0,25"
                >
                    <TextBlock
                        Text="Calculating folder sizes. This may take a moment."
                        FontSize="20"
                        TextWrapping="WrapWholeWords"
                        HorizontalAlignment="Stretch"
                        />
                    <ProgressRing 
                        IsActive="True"
                        Width="20"
                        Height="20" />
                </StackPanel>
                <!-- Toolbar for sorting and opening the current folder in File Explorer. -->
                <Grid MaxWidth="750" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock 
                            Text="Sort by:" 
                            FontSize="16" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,12,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ComboBox 
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            MinWidth="150"
                            FontSize="15"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}"
                            />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                        <Button
                            Click="Refresh_Click"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                        <Button 
                            Content="View Folder in File Explorer"
                            Click="ViewFileExplorer_Click"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolInverter}}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Row="2">
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    >
                </StackPanel>
                <!-- Breadcrumb path from root to the active folder. -->
                <ListView ItemsSource="{Binding PathItems, Mode=OneWay}"
                          MaxWidth="750"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,7"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="/" FontSize="24" Opacity="{Binding ElementName=RootPage, Path=ViewModel.FolderItemOpacity}" />
                                <Button
                                    Click="BreadCrumb_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    CommandParameter="{Binding Index}"
                                    IsEnabled="{Binding ElementName=RootPage, Path=ViewModel.IsLoading, Converter={StaticResource BoolInverter}}">
                                    <TextBlock Text="{Binding Name}" FontSize="24" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Rectangle Height="2" 
                   Width="750" 
                   Fill="Black" 
                   HorizontalAlignment="Center"/>
                <!-- Folder/file rows for the active directory level. -->
                <ItemsRepeater ItemsSource="{Binding ActiveNode.Children, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Button
                                    Click="Folder_Click"
                                    CommandParameter="{Binding FilePath}"
                                    MaxWidth="750"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,8"
                                    Opacity="{Binding ElementName=RootPage, Path=ViewModel.FolderItemOpacity}"
                                    IsEnabled="{Binding ElementName=RootPage, Path=ViewModel.IsLoading, Converter={StaticResource BoolInverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            >
                                            <FontIcon
                                                Glyph="{Binding Type, Converter={StaticResource FolderItemTypeToGlyphConverter}}" 
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                            <TextBlock
                                                Text="{Binding Name}"
                                                FontSize="24"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding Finished, Mode=OneWay, Converter={StaticResource BoolToCollapsedConverter}}">
                                            <ProgressRing 
                                                IsActive="True"
                                                Width="10"
                                                Height="10" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding Finished, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock 
                                                Text="{Binding Size}"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                            <TextBlock 
                                                Text="{Binding DataLabel}"
                                                Foreground="{Binding AnnouncementTextColor}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Rectangle Height="1" 
                                   Width="750" 
                                   Fill="Black" 
                                   HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
