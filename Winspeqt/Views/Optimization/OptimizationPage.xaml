<Page
    x:Class="Winspeqt.Views.Optimization.OptimizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    xmlns:models="using:Winspeqt.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <helpers:BoolInverter x:Key="InverseBoolConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="BackButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                        <TextBlock Text="Optimization Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Grid
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,4"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        Glyph="&#xEA99;"
                        FontSize="40"
                        Foreground="#4CAF50"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"/>
                    <TextBlock
                        Grid.Column="1"
                        Text="One-Click Optimization"
                        FontSize="36"
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords"
                        VerticalAlignment="Center"/>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Clean up junk files and free up space with a single click"
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords"
                    Margin="0,4,0,0"/>
            </Grid>

            <!-- Main Action Card -->
            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="16"
                Padding="40"
                Margin="0,0,0,24">
                <StackPanel>

                    <!-- Running State -->
                    <StackPanel
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,32">
                        <ProgressRing
                            IsActive="{Binding IsRunning}"
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"/>
                        <TextBlock
                            Text="{Binding CurrentTaskLabel}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8"/>
                        <TextBlock
                            Text="Please wait, do not close the app..."
                            FontSize="14"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Results Summary (shown after a run, ALWAYS at top) -->
                    <StackPanel
                        Visibility="{Binding HasCompleted, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,32">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <FontIcon 
                                Glyph="&#xE73A;" 
                                Foreground="#4CAF50" 
                                Margin="0,0,4,0"/>
                            <TextBlock
                                Text="Last Optimization Results"
                                FontSize="18"
                                FontWeight="SemiBold"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.FormattedBytesFreed}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#4CAF50"/>
                                    <TextBlock Text="Space Freed" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="12" Padding="20" Margin="8,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.TasksCompleted}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#4CAF50"/>
                                    <TextBlock Text="Tasks Done" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.TasksFailed}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF9800"/>
                                    <TextBlock Text="Skipped" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Result.TaskResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:OptimizationTaskResult">
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8" Padding="16,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{x:Bind Color}"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind TaskName}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{x:Bind StatusMessage}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{x:Bind FormattedBytesFreed}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Idle/Ready State (always visible unless running) -->
                    <StackPanel Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                            <FontIcon 
                                Glyph="&#xEA99;" 
                                FontSize="64"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16"
                                Foreground="#4CAF50"/>
                            <TextBlock
                                Text="Ready to Optimize"
                                FontSize="26"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8"/>

                            <!-- Estimated size -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,4">
                                <ProgressRing
                                    IsActive="{Binding IsScanning}"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Width="18" Height="18"/>
                                <TextBlock
                                    Text="{Binding EstimatedTotal}"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="#4CAF50"
                                    HorizontalAlignment="Center"/>
                                <TextBlock
                                    Text="estimated to be freed"
                                    FontSize="15"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <TextBlock
                                Text="Winspeqt will safely clean up junk files from your PC."
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                MaxWidth="480"/>
                        </StackPanel>

                        <!-- Task List -->
                        <StackPanel Spacing="8" Margin="0,32,0,32">

                            <!-- Run Button -->
                            <Button
                                x:Name="RunButton"
                                Command="{Binding RunOptimizationCommand}"
                                HorizontalAlignment="Center"
                                Padding="48,16"
                                CornerRadius="12"
                                Margin="0,0,0,32">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon 
                                        Glyph="&#xE724;"
                                        Foreground="#F44336"
                                        Margin="0,0,12,0"/>
                                    <TextBlock 
                                        Text="Run Optimization" 
                                        FontSize="18"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <TextBlock
                                Text="Select what to clean"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>

                            <!-- Recycle Bin -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE74D;" FontSize="24" Foreground="#feb800" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Recycle Bin" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Permanently deletes files you've already sent to the Recycle Bin." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanRecycleBin, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeRecycleBin}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Temp Files -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="24" Foreground="#f14f21" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Temporary Files" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Removes leftover files apps create while running. They're no longer needed once the app closes." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanTempFiles, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeTempFiles}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Thumbnail Cache -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE91B;" FontSize="24" Foreground="#7eb900" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Thumbnail Cache" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears the preview images Windows stores for your files. They'll rebuild automatically next time you browse." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanThumbnailCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeThumbnailCache}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- This is currently unimplemented; hiding tile -->
                            <!-- DNS Cache -->
                            <!--
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="24" Foreground="#00a3ee" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="DNS Cache" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Flushes your PC's memory of website addresses. Useful if websites aren't loading correctly." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding FlushDnsCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>-->

                            <!-- Prefetch -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE945;" FontSize="24" Foreground="#feb800" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Prefetch Files" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Removes files Windows uses to speed up app launches. They'll be recreated automatically over time." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanPrefetch, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizePrefetch}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Error Reports -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E3;" FontSize="24" Foreground="#f14f21" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Error Reports" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Deletes crash reports Windows saves when apps stop working. Safe to remove once you've resolved any issues." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanWindowsErrorReports, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeErrorReports}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Crash Dumps -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE7BC;" FontSize="24" Foreground="#7eb900" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Crash Dump Files" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Removes memory snapshots saved when your PC crashes. Only needed for diagnosing issues." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanCrashDumps, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeCrashDumps}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Windows Update Cache -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE895;" FontSize="24" Foreground="#00a3ee" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Update Cache" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears downloaded update files that have already been installed. Safe to remove anytime." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanUpdateCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeUpdateCache}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- This is currently unimplemented; hiding tile -->
                            <!-- Event Logs -->
                            <!--
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE9F9;" FontSize="24" Foreground="#feb800" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Event Logs" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears Windows system and application logs. Skip this if your PC is managed by IT support." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanEventLogs, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>-->

                            <!-- Edge Cache -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE909;" FontSize="24" Foreground="#f14f21" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Microsoft Edge Cache" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears Edge's temporary browsing cache. Websites may load slightly slower on your first visit after cleaning." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanBrowserCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeEdgeCache}" FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
