<Page
    x:Class="Winspeqt.Views.Optimization.OptimizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Winspeqt.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Winspeqt.Helpers"
    xmlns:models="using:Winspeqt.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <helpers:BoolInverter x:Key="InverseBoolConverter"/>

        <Style x:Key="OptimizationSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="OptimizationOptionRowStyle" TargetType="Border" BasedOn="{StaticResource CompactCardBorderStyle}">
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="OptimizationOptionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="OptimizationOptionBodyStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="OptimizationMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OptimizationMetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="OptimizationResultTemplate" x:DataType="models:OptimizationTaskResult">
            <Border Style="{StaticResource MetricTileBorderStyle}" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{x:Bind Color}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind TaskName}" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                        <TextBlock Text="{x:Bind StatusMessage}" Style="{StaticResource OptimizationOptionBodyStyle}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{x:Bind FormattedBytesFreed}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:StandardPageHeader
                Grid.Row="0"
                BackText="Optimization Home"
                BackRequested="BackButton_Click"
                IconGlyph="&#xEA99;"
                IconBrush="{StaticResource FeatureSuccessBrush}"
                Title="One-Click Optimization"
                Subtitle="Clean up junk files and free up space with a single click" />

            <Border
                Grid.Row="1"
                Style="{StaticResource HeroCardBorderStyle}"
                Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,32">
                        <ProgressRing
                            IsActive="{Binding IsRunning}"
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"/>
                        <TextBlock
                            Text="{Binding CurrentTaskLabel}"
                            Style="{StaticResource SectionTitleTextStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8"/>
                        <TextBlock
                            Text="Please wait, do not close the app..."
                            Style="{StaticResource CaptionTextStyle}"
                            HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel
                        Visibility="{Binding HasCompleted, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,32">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <FontIcon
                                Glyph="&#xE73A;"
                                Foreground="{StaticResource FeatureSuccessBrush}"
                                Margin="0,0,4,0"/>
                            <TextBlock
                                Text="Last Optimization Results"
                                Style="{StaticResource SectionTitleTextStyle}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MetricTileBorderStyle}" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.FormattedBytesFreed}" Style="{StaticResource OptimizationMetricValueStyle}" Foreground="{StaticResource FeatureSuccessBrush}"/>
                                    <TextBlock Text="Space Freed" Style="{StaticResource OptimizationMetricLabelStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MetricTileBorderStyle}" Margin="8,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.TasksCompleted}" Style="{StaticResource OptimizationMetricValueStyle}" Foreground="{StaticResource FeatureSuccessBrush}"/>
                                    <TextBlock Text="Tasks Done" Style="{StaticResource OptimizationMetricLabelStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource MetricTileBorderStyle}" Margin="8,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Result.TasksFailed}" Style="{StaticResource OptimizationMetricValueStyle}" Foreground="{StaticResource FeatureAttentionBrush}"/>
                                    <TextBlock Text="Skipped" Style="{StaticResource OptimizationMetricLabelStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Result.TaskResults}" ItemTemplate="{StaticResource OptimizationResultTemplate}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                            <FontIcon
                                Glyph="&#xEA99;"
                                FontSize="64"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16"
                                Foreground="{StaticResource FeatureSuccessBrush}"/>
                            <TextBlock
                                Text="Ready to Optimize"
                                FontSize="26"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,4">
                                <ProgressRing
                                    IsActive="{Binding IsScanning}"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Width="18"
                                    Height="18"/>
                                <TextBlock
                                    Text="{Binding EstimatedTotal}"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource FeatureSuccessBrush}"
                                    HorizontalAlignment="Center"/>
                                <TextBlock
                                    Text="estimated to be freed"
                                    FontSize="15"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <TextBlock
                                Text="Winspeqt will safely clean up junk files from your PC."
                                FontSize="15"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                MaxWidth="480"/>
                        </StackPanel>

                        <StackPanel Spacing="8" Margin="0,32,0,32">
                            <Button
                                x:Name="RunButton"
                                Command="{Binding RunOptimizationCommand}"
                                Style="{StaticResource DangerActionButtonStyle}"
                                HorizontalAlignment="Center"
                                Padding="48,16"
                                Margin="0,0,0,32">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon
                                        Glyph="&#xE724;"
                                        Margin="0,0,12,0"/>
                                    <TextBlock
                                        Text="Run Optimization"
                                        FontSize="18"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>

                            <TextBlock
                                Text="Select what to clean"
                                Style="{StaticResource OptimizationSectionLabelStyle}"
                                Margin="0,0,0,4"/>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE74D;" FontSize="24" Foreground="{StaticResource FeatureAttentionBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Recycle Bin" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Permanently deletes files you've already sent to the Recycle Bin." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanRecycleBin, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeRecycleBin}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="24" Foreground="{StaticResource FeatureCriticalBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Temporary Files" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Removes leftover files apps create while running. They're no longer needed once the app closes." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanTempFiles, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeTempFiles}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE91B;" FontSize="24" Foreground="{StaticResource FeatureSuccessBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Thumbnail Cache" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Clears the preview images Windows stores for your files. They'll rebuild automatically next time you browse." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanThumbnailCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeThumbnailCache}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            
                            <!-- This is currently unimplemented; hiding tile -->
                            <!-- DNS Cache -->
                            <!--
                             <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="24" Foreground="#00a3ee" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                     <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                         <TextBlock Text="DNS Cache" FontSize="15" FontWeight="SemiBold"/>
                                         <TextBlock Text="Flushes your PC's memory of website addresses. Useful if websites aren't loading correctly." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                     </StackPanel>
                                     <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="44"/>
                                             <ColumnDefinition Width="64"/>
                                         </Grid.ColumnDefinitions>
                                         <CheckBox Grid.Column="0" IsChecked="{Binding FlushDnsCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Column="1" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                     </Grid>
                                 </Grid>
                             </Border>-->

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE945;" FontSize="24" Foreground="{StaticResource FeatureAttentionBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Prefetch Files" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Removes files Windows uses to speed up app launches. They'll be recreated automatically over time." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanPrefetch, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizePrefetch}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E3;" FontSize="24" Foreground="{StaticResource FeatureCriticalBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Error Reports" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Deletes crash reports Windows saves when apps stop working. Safe to remove once you've resolved any issues." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanWindowsErrorReports, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeErrorReports}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE7BC;" FontSize="24" Foreground="{StaticResource FeatureSuccessBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Crash Dump Files" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Removes memory snapshots saved when your PC crashes. Only needed for diagnosing issues." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanCrashDumps, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeCrashDumps}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE895;" FontSize="24" Foreground="{StaticResource FeatureAccentBlueBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Update Cache" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Clears downloaded update files that have already been installed. Safe to remove anytime." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanUpdateCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeUpdateCache}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            
                            <!-- This is currently unimplemented; hiding tile -->
                            <!-- Event Logs -->
                            <!--
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE9F9;" FontSize="24" Foreground="#feb800" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Event Logs" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears Windows system and application logs. Skip this if your PC is managed by IT support." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanEventLogs, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>-->

                            <Border Style="{StaticResource OptimizationOptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE909;" FontSize="24" Foreground="{StaticResource FeatureCriticalBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Microsoft Edge Cache" Style="{StaticResource OptimizationOptionTitleStyle}"/>
                                        <TextBlock Text="Clears Edge's temporary browsing cache. Websites may load slightly slower on your first visit after cleaning." Style="{StaticResource OptimizationOptionBodyStyle}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding CleanBrowserCache, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeEdgeCache}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FeatureSuccessBrush}" Margin="4,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
