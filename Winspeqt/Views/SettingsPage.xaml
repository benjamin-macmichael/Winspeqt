<Page
    x:Class="Winspeqt.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winspeqt.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:StartupButtonColorConverter x:Key="StartupButtonColorConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="30,30,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button
                Grid.Row="0"
                Grid.Column="0"
                Click="BackButton_Click"
                Background="Transparent"
                BorderThickness="0"
                Padding="8"
                Margin="0,0,20,0"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                    <TextBlock Text="Home" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Grid
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,0,4"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon
                    Grid.Column="0"
                    Glyph="&#xE713;"
                    FontSize="40"
                    Foreground="#FF9800"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"/>
                <TextBlock
                    Grid.Column="1"
                    Text="Settings"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    TextWrapping="WrapWholeWords"
                    VerticalAlignment="Center"/>
            </Grid>

            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Text="Manage how Winspeqt behaves on your system"
                FontSize="18"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
                Margin="0,4,0,0"/>
        </Grid>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" Padding="30,0,30,30" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- Startup Section -->
                <TextBlock
                    Text="SYSTEM"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    CharacterSpacing="150"
                    Margin="0,0,0,4"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border
                            Grid.Column="0"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="8"
                            Width="44"
                            Height="44"
                            Margin="0,0,16,0">
                            <FontIcon
                                Glyph="&#xE7E8;"
                                FontSize="20"
                                Foreground="#007ACC"/>
                        </Border>

                        <!-- Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock
                                Text="Launch at Startup"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock
                                Text="Winspeqt will run quietly at startup, ready to deliver its background features."
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            Content="{Binding StartupButtonText}"
                            Click="StartupButton_Click"
                            Background="{Binding LaunchAtStartup, Converter={StaticResource StartupButtonColorConverter}}"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="6"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Notifications Section -->
                <TextBlock
                    Text="NOTIFICATIONS"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    CharacterSpacing="150"
                    Margin="0,8,0,4"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="More notification settings coming soon"
                            FontSize="14"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock
                            Text="Health score alerts, weekly app scan summaries, and more will appear here."
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Data and Privacy Section -->
                <TextBlock
                    Text="DATA AND PRIVACY"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    CharacterSpacing="150"
                    Margin="0,8,0,4"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap">
                            Winspeqt captures app usage, settings, file storage, and other system information.
                            This information is necessary to make Winspeqt's features work. However, this data
                            still belongs to you. We never move it off your computer and only ever use it to show
                            you how your computer is behaving. If you have any questions, please reach out at
                            <Hyperlink NavigateUri="mailto:winspeqtsupport@byu.onmicrosoft.com" Click="Hyperlink_Click">winspeqtsupport@byu.onmicrosoft.com</Hyperlink>.
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Button
                    x:Name="FeedbackButton"
                    Style="{StaticResource FloatingFeedbackButtonStyle}"
                    Content="Feedback"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="16"
                    Canvas.ZIndex="10"
                    Click="FeedbackButton_Click"
                    Foreground="WhiteSmoke"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
