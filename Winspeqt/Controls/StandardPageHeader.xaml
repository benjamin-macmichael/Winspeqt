<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Winspeqt.Controls.StandardPageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Grid Margin="{Binding ElementName=Root, Path=HeaderMargin}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            Grid.Row="0"
            Grid.Column="0"
            Style="{StaticResource PageBackButtonStyle}"
            Click="BackButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE76B;" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ElementName=Root, Path=BackText}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <Grid
            Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,0,4"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Grid.Column="0"
                Glyph="{Binding ElementName=Root, Path=IconGlyph}"
                FontSize="{StaticResource PageHeaderIconSize}"
                Foreground="{Binding ElementName=Root, Path=IconBrush}"
                Margin="{StaticResource PageHeaderIconMargin}"
                VerticalAlignment="Center"
                Visibility="{Binding ElementName=Root, Path=IconVisibility}" />

            <TextBlock
                Grid.Column="1"
                Text="{Binding ElementName=Root, Path=Title}"
                Style="{StaticResource PageTitleTextStyle}" />
        </Grid>

        <TextBlock
            Grid.Row="1"
            Grid.Column="1"
            Text="{Binding ElementName=Root, Path=Subtitle}"
            Style="{StaticResource PageSubtitleTextStyle}" />

        <Button
            Grid.Row="0"
            Grid.Column="2"
            Command="{Binding ElementName=Root, Path=ActionCommand}"
            Visibility="{Binding ElementName=Root, Path=ActionVisibility}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    Glyph="{Binding ElementName=Root, Path=ActionGlyph}"
                    FontSize="15"
                    VerticalAlignment="Center"
                    Visibility="{Binding ElementName=Root, Path=ActionGlyphVisibility}" />
                <TextBlock Text="{Binding ElementName=Root, Path=ActionText}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
