<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DashboardBackButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource DashboardBackButtonPadding}" />
        <Setter Property="Margin" Value="{StaticResource DashboardBackButtonMargin}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PageBackButtonStyle" TargetType="Button" BasedOn="{StaticResource DashboardBackButtonStyle}">
        <Setter Property="Padding" Value="{StaticResource PageBackButtonPadding}" />
        <Setter Property="Margin" Value="{StaticResource PageBackButtonMargin}" />
    </Style>

    <Style x:Key="DashboardCardButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
    </Style>

    <Style x:Key="DashboardMetricButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SecondaryOutlineActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource NeutralActionBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NeutralActionBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ActionPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="PageHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DangerActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ActionDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
</ResourceDictionary>
